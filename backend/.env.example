# Copy to `.env`, or keep secrets in `.env.local` / `.env.prod` and use:
#   make run-local        # cp .env.local .env && go run ./cmd/api
#   make run-production   # cp .env.prod .env && go run ./cmd/api
# (Run those from the `backend/` directory.)

BITIK_APP_ENVIRONMENT=local
BITIK_APP_VERSION=dev
BITIK_APP_COMMIT=local
BITIK_HTTP_ADDR=:8080
# When set (e.g. :9090), Prometheus metrics are served only on this address, not on the public API server.
BITIK_HTTP_METRICS_ADDR=
BITIK_SECURITY_MAX_REQUEST_BODY_BYTES=1048576
BITIK_SECURITY_MAX_UPLOAD_BYTES=10485760
BITIK_AUTH_JWT_SECRET=change-me
BITIK_AUTH_LOG_SECRETS=false
BITIK_AUTH_MAX_LOGIN_FAILURES=8
BITIK_AUTH_LOGIN_LOCKOUT_DURATION=20m
BITIK_AUTH_OTP_MAX_VERIFY_FAILURES=5
BITIK_AUTH_REFRESH_COOKIE_SAME_SITE=lax
# OAuth client settings. Apple private key can contain escaped newlines.
# BITIK_AUTH_OAUTH_GOOGLE_CLIENT_ID=
# BITIK_AUTH_OAUTH_GOOGLE_CLIENT_SECRET=
# BITIK_AUTH_OAUTH_FACEBOOK_APP_ID=
# BITIK_AUTH_OAUTH_FACEBOOK_APP_SECRET=
# BITIK_AUTH_OAUTH_APPLE_CLIENT_ID=
# BITIK_AUTH_OAUTH_APPLE_TEAM_ID=
# BITIK_AUTH_OAUTH_APPLE_KEY_ID=
# BITIK_AUTH_OAUTH_APPLE_PRIVATE_KEY_PEM=
BITIK_DATABASE_URL=postgres://bitik:bitik@127.0.0.1:55432/bitik?sslmode=disable
# When true, `cmd/api` runs Goose up before serving. Set false in prod if migrations run in CI/CD only.
BITIK_DATABASE_AUTO_MIGRATE=true
BITIK_DATABASE_CONNECT_TIMEOUT=5s
BITIK_DATABASE_QUERY_TIMEOUT=10s
# Optional absolute path to migrations (default: ./db/migrations or ./backend/db/migrations from cwd).
# BITIK_MIGRATIONS_DIR=
BITIK_REDIS_ADDR=localhost:6379
BITIK_RABBITMQ_URL=amqp://bitik:bitik@localhost:5672/
BITIK_PAYMENTS_WEBHOOK_SECRET=
BITIK_STORAGE_ENDPOINT=localhost:9000
BITIK_STORAGE_ACCESS_KEY_ID=minioadmin
BITIK_STORAGE_SECRET_ACCESS_KEY=minioadmin
BITIK_STORAGE_BUCKET=bitik-local
BITIK_SEARCH_URL=http://localhost:9200
BITIK_OBSERVABILITY_LOG_LEVEL=info
BITIK_OBSERVABILITY_TRACING_ENABLED=false
BITIK_OBSERVABILITY_OTLP_ENDPOINT=localhost:4317
BITIK_OBSERVABILITY_SAMPLE_RATIO=1.0

# Optional deploy/runtime helpers used by scripts in `backend/scripts`.
# DEPLOY_HOST=
# DEPLOY_USER=
# DEPLOY_PATH=
# SMOKE_BASE_URL=

BITIK_IDEMPOTENCY_TTL=24h
BITIK_IDEMPOTENCY_MAX_BODY_BYTES=262144
BITIK_IDEMPOTENCY_LOCK_TTL=2m
BITIK_IDEMPOTENCY_WAIT_TIMEOUT=30s
BITIK_IDEMPOTENCY_POLL_INTERVAL=50ms
