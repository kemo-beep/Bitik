# Monorepo — merged from bitik-web, bitik-mobile, backend

# Editor / local tooling
.cursor/

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Backend (Go)
/backend/.env
/backend/.env.local
/backend/.env.prod
/backend/internal/.env
*.test
/backend/bin/

# Next.js (bitik-web)
bitik-web/.next/
bitik-web/out/
bitik-web/build
bitik-web/coverage/
bitik-web/next-env.d.ts

# Expo / React Native (bitik-mobile)
bitik-mobile/.expo/
bitik-mobile/dist/
bitik-mobile/web-build/
bitik-mobile/expo-env.d.ts
bitik-mobile/.kotlin/
bitik-mobile/.metro-health-check*
bitik-mobile/app-example
# Native / signing artifacts (match anywhere; rarely used outside mobile)
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
/bitik-mobile/ios
/bitik-mobile/android

# OS / misc
.DS_Store
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env (local overrides)
.env*.local

# TypeScript (repo-wide generated caches)
*.tsbuildinfo
